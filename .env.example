# ==============================================================================
# Online Cinema API - Environment Template
# ==============================================================================
# Copy this file to .env and fill in real values
# ==============================================================================

# ==============================================================================
# DATABASE CONFIGURATION
# ==============================================================================
POSTGRES_USER=your_postgres_user
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=your_database_name
POSTGRES_PORT=5432
DATABASE_URL=postgresql://your_postgres_user:your_postgres_password@postgres:5432/your_database_name

# ==============================================================================
# JWT AUTHENTICATION SETTINGS
# ==============================================================================
SECRET_KEY=generate_a_secure_random_64_char_hex_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ==============================================================================
# EMAIL CONFIGURATION
# ==============================================================================
SMTP_HOST=smtp.your-email-provider.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-app-password
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=Online Cinema

# ==============================================================================
# FRONTEND CONFIGURATION
# ==============================================================================
FRONTEND_URL=http://localhost:3000

# ==============================================================================
# REDIS CONFIGURATION
# ==============================================================================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==============================================================================
# CELERY CONFIGURATION
# ==============================================================================
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ==============================================================================
# TOKEN EXPIRATION SETTINGS
# ==============================================================================
ACTIVATION_TOKEN_EXPIRE_HOURS=24
PASSWORD_RESET_TOKEN_EXPIRE_HOURS=1

# ==============================================================================
# STRIPE PAYMENT GATEWAY
# ==============================================================================
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
STRIPE_WEBHOOK_SECRET=your_stripe_webhook_secret

# ==============================================================================
# MINIO OBJECT STORAGE
# ==============================================================================
MINIO_ROOT_USER=your_minio_root_user
MINIO_ROOT_PASSWORD=your_minio_root_password
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ENDPOINT=minio:9000

# ==============================================================================
# API CONFIGURATION
# ==============================================================================
API_PORT=8000
API_HOST=0.0.0.0
ENVIRONMENT=development
DEBUG=true

# ==============================================================================
# NGINX CONFIGURATION
# ==============================================================================
NGINX_PORT=80

# ==============================================================================
# LOGGING CONFIGURATION
# ==============================================================================
LOG_LEVEL=INFO
LOG_FILE=/var/log/online-cinema/app.log

# ==============================================================================
# CORS CONFIGURATION
# ==============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ==============================================================================
# SECURITY SETTINGS
# ==============================================================================
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15

# ==============================================================================
# FILE UPLOAD SETTINGS
# ==============================================================================
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.pdf

# ==============================================================================
# RATE LIMITING
# ==============================================================================
RATE_LIMIT_PER_MINUTE=60

# ==============================================================================
# PAGINATION DEFAULTS
# ==============================================================================
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ==============================================================================
# DOCKER CONFIGURATION
# ==============================================================================
COMPOSE_PROJECT_NAME=online-cinema
DOCKER_NETWORK=cinema_network

# ==============================================================================
# TESTING CONFIGURATION
# ==============================================================================
TEST_DATABASE_URL=sqlite:///:memory:

# ==============================================================================
# BACKUP CONFIGURATION
# ==============================================================================
BACKUP_DIR=/backups
BACKUP_RETENTION_DAYS=30

